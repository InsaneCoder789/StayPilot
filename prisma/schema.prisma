generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  HOTEL_ADMIN
  MANAGER
  RECEPTIONIST
  HOUSEKEEPING
  MAINTENANCE
  ACCOUNTANT
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum RoomStatus {
  AVAILABLE
  RESERVED
  OCCUPIED
  DIRTY
  CLEANING
  MAINTENANCE
  BLOCKED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW
}

enum PaymentState {
  UNPAID
  PARTIAL
  PAID
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  BANK_TRANSFER
  OTA_VCC
}

enum TransactionStatus {
  CAPTURED
  REFUNDED
  FAILED
}

enum InvoiceStatus {
  UNPAID
  PARTIAL
  PAID
  VOID
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum WorkStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum ComplaintStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

enum AccessType {
  NFC
  MAGSTRIPE
  RFID
}

enum CardStatus {
  READY
  ENCODED
  ACTIVE
  EXPIRED
}

enum AccessEventType {
  ENCODED
  ACCESS_GRANTED
  ACCESS_DENIED
  EXPIRED
}

enum BlueprintZoneType {
  ROOM
  LOBBY
  SERVICE
  STAIR
  LIFT
  AMENITY
}

enum GatewayStatus {
  READY
  OFFLINE
}

enum DocumentType {
  INVOICE
  POLICY
  GUEST_FORM
  ROOM_CARD_LOG
  AUDIT
  HANDOVER
  RECEIPT
  BLUEPRINT
  OTHER
}

enum InventoryCategory {
  LINEN
  AMENITY
  MINIBAR
  HOUSEKEEPING
  ENGINEERING
}

enum VendorCategory {
  HVAC
  PLUMBING
  LINEN
  IT
  SUPPLIER
}

enum Department {
  FRONT_DESK
  HOUSEKEEPING
  MAINTENANCE
}

enum NightAuditStatus {
  PENDING
  COMPLETED
}

enum IntegrationType {
  OTA
  PAYMENT
  EMAIL
  WHATSAPP
  NFC_LOCK
  ACCOUNTING
}

enum IntegrationStatus {
  DISCONNECTED
  READY
  CONNECTED
}

enum RagDocumentStatus {
  UPLOADED
  PROCESSING
  READY
  FAILED
}

model Hotel {
  id                 String              @id @default(cuid())
  name               String
  legalName          String
  propertyCode       String              @unique
  addressLine1       String
  addressLine2       String?
  city               String
  state              String
  postalCode         String?
  country            String
  currency           String              @default("AED")
  phone              String
  email              String
  taxRegistrationNo  String?
  taxRate            Decimal             @default(0) @db.Decimal(5, 2)
  checkInTime        String
  checkOutTime       String
  timezone           String
  themeMode          String              @default("dark")
  themeAccent        String              @default("#8eb69b")
  themeSurface       String              @default("#13191d")
  themeSurfaceStrong String              @default("#1a2329")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  users              User[]
  sessions           Session[]
  staffInvitations   StaffInvitation[]
  loginAttempts      LoginAttempt[]
  roomTypes          RoomType[]
  rooms              Room[]
  roomStatusLogs     RoomStatusLog[]
  guests             Guest[]
  groups             GroupReservation[]
  bookings           Booking[]
  housekeepingTasks  HousekeepingTask[]
  maintenanceTickets MaintenanceTicket[]
  complaints         Complaint[]
  invoices           Invoice[]
  payments           Payment[]
  receipts           Receipt[]
  policies           Policy[]
  roomCards          RoomCard[]
  accessEvents       NfcAccessEvent[]
  blueprints         Blueprint[]
  paymentGateways    PaymentGateway[]
  documents          Document[]
  notifications      Notification[]
  auditLogs          AuditLog[]
  inventoryItems     InventoryItem[]
  vendors            Vendor[]
  handovers          ShiftHandover[]
  nightAudits        NightAudit[]
  integrations       Integration[]
  ragDocuments       RagDocument[]
  aiInteractions     AiInteraction[]
}

model User {
  id            String         @id @default(cuid())
  hotelId       String
  name          String
  email         String
  phone         String?
  passwordHash  String
  role          UserRole
  status        UserStatus     @default(ACTIVE)
  employeeCode  String?
  department    String?
  shiftLabel    String?
  workload      String?
  lastLoginAt   DateTime?
  failedLoginAttempts Int            @default(0)
  lockedUntil        DateTime?
  passwordChangedAt DateTime         @default(now())
  mfaEnabled         Boolean          @default(false)
  mfaSecretEncrypted String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  hotel         Hotel          @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  sessions      Session[]
  passwordResetTokens PasswordResetToken[]
  auditLogs     AuditLog[]
  notifications Notification[]

  @@unique([hotelId, email])
  @@unique([hotelId, employeeCode])
  @@index([hotelId, role, status])
}

model Session {
  id         String    @id @default(cuid())
  hotelId    String
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  userAgent  String?
  ipAddress  String?
  deviceName String?
  createdAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  revokedAt  DateTime?
  hotel      Hotel     @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([hotelId, revokedAt])
}

model StaffInvitation {
  id            String    @id @default(cuid())
  hotelId       String
  email         String
  name          String
  role          UserRole
  tokenHash     String    @unique
  createdByName String
  expiresAt     DateTime
  acceptedAt    DateTime?
  revokedAt     DateTime?
  createdAt     DateTime  @default(now())
  hotel         Hotel     @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId, email, expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  hotelId   String?
  email     String
  ipAddress String?
  success   Boolean
  reason    String
  createdAt DateTime @default(now())
  hotel     Hotel?   @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
  @@index([hotelId, createdAt])
}

model RoomType {
  id          String   @id @default(cuid())
  hotelId     String
  name        String
  description String?
  basePrice   Decimal  @db.Decimal(12, 2)
  capacity    Int
  bedType     String
  amenities   Json
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  hotel       Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  rooms       Room[]

  @@unique([hotelId, name])
  @@index([hotelId, active])
}

model Room {
  id                 String              @id @default(cuid())
  hotelId            String
  roomTypeId         String
  roomNumber         String
  floor              Int
  status             RoomStatus          @default(AVAILABLE)
  capacity           Int
  guestName          String?
  nextBookingAt      DateTime?
  housekeepingNote   String?
  notes              String?
  outOfService       Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  hotel              Hotel               @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  roomType           RoomType            @relation(fields: [roomTypeId], references: [id], onDelete: Restrict)
  bookings           Booking[]
  housekeepingTasks  HousekeepingTask[]
  maintenanceTickets MaintenanceTicket[]
  complaints         Complaint[]
  roomCards          RoomCard[]
  zones              BlueprintZone[]
  statusLogs         RoomStatusLog[]

  @@unique([hotelId, roomNumber])
  @@index([hotelId, floor, status])
  @@index([hotelId, roomTypeId, status])
}

model RoomStatusLog {
  id        String     @id @default(cuid())
  hotelId   String
  roomId    String
  oldStatus RoomStatus
  newStatus RoomStatus
  userId    String?
  reason    String?
  createdAt DateTime   @default(now())
  hotel     Hotel      @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  room      Room       @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([hotelId, roomId, createdAt])
}

model Guest {
  id            String      @id @default(cuid())
  hotelId       String
  firstName     String
  lastName      String
  phone         String
  email         String
  nationality   String
  dateOfBirth   DateTime?
  address       String?
  vipStatus     Boolean     @default(false)
  preferences   Json
  notes         String      @default("")
  stayCount     Int         @default(0)
  loyaltyPoints Int         @default(0)
  loyaltyTier   String      @default("BRONZE")
  companyName   String?
  blacklisted   Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  hotel         Hotel       @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  bookings      Booking[]
  invoices      Invoice[]
  complaints    Complaint[]

  @@index([hotelId, lastName, firstName])
  @@index([hotelId, phone])
  @@index([hotelId, email])
}

model GroupReservation {
  id          String    @id @default(cuid())
  hotelId     String
  groupName   String
  companyName String?
  roomCount   Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  hotel       Hotel     @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  bookings    Booking[]

  @@index([hotelId, createdAt])
}

model Booking {
  id                 String            @id @default(cuid())
  hotelId            String
  code               String
  guestId            String
  groupReservationId String?
  roomId             String?
  guestName          String
  roomTypeName       String
  status             BookingStatus     @default(CONFIRMED)
  source             String
  checkInAt          DateTime
  checkOutAt         DateTime
  paymentStatus      PaymentState      @default(UNPAID)
  advancePaid        Decimal           @default(0) @db.Decimal(12, 2)
  totalAmount        Decimal           @db.Decimal(12, 2)
  specialRequests    String            @default("")
  companyName        String?
  actualCheckInAt    DateTime?
  actualCheckOutAt   DateTime?
  createdByUserId    String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  hotel              Hotel             @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  guest              Guest             @relation(fields: [guestId], references: [id], onDelete: Restrict)
  groupReservation   GroupReservation? @relation(fields: [groupReservationId], references: [id], onDelete: SetNull)
  room               Room?             @relation(fields: [roomId], references: [id], onDelete: SetNull)
  invoices           Invoice[]
  roomCards          RoomCard[]

  @@unique([hotelId, code])
  @@index([hotelId, status, checkInAt])
  @@index([hotelId, status, checkOutAt])
  @@index([hotelId, guestId])
}

model HousekeepingTask {
  id                String     @id @default(cuid())
  hotelId           String
  roomId            String
  status            WorkStatus @default(PENDING)
  priority          Priority
  taskType          String     @default("CHECKOUT_CLEANING")
  checkoutAt        DateTime?
  nextCheckInAt     DateTime?
  assignee          String     @default("Unassigned")
  checklistComplete Boolean    @default(false)
  notes             String?
  completedAt       DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  hotel             Hotel      @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  room              Room       @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([hotelId, status, priority])
  @@index([hotelId, roomId])
}

model Vendor {
  id                 String              @id @default(cuid())
  hotelId            String
  name               String
  category           VendorCategory
  contact            String
  email              String?
  sla                String
  active             Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  hotel              Hotel               @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  inventoryItems     InventoryItem[]
  maintenanceTickets MaintenanceTicket[]

  @@unique([hotelId, name])
  @@index([hotelId, category, active])
}

model MaintenanceTicket {
  id          String            @id @default(cuid())
  hotelId     String
  roomId      String?
  vendorId    String?
  title       String
  category    String
  priority    Priority
  status      MaintenanceStatus @default(OPEN)
  assignee    String            @default("Unassigned")
  description String
  resolution  String?
  resolvedAt  DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  hotel       Hotel             @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  room        Room?             @relation(fields: [roomId], references: [id], onDelete: SetNull)
  vendor      Vendor?           @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  @@index([hotelId, status, priority])
  @@index([hotelId, roomId])
}

model Complaint {
  id         String          @id @default(cuid())
  hotelId    String
  guestId    String?
  roomId     String?
  guestName  String
  category   String
  priority   Priority
  status     ComplaintStatus @default(OPEN)
  department String
  message    String
  resolution String?
  resolvedAt DateTime?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  hotel      Hotel           @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  guest      Guest?          @relation(fields: [guestId], references: [id], onDelete: SetNull)
  room       Room?           @relation(fields: [roomId], references: [id], onDelete: SetNull)

  @@index([hotelId, status, priority])
}

model Invoice {
  id              String        @id @default(cuid())
  hotelId         String
  bookingId       String?
  guestId         String?
  invoiceNumber   String
  bookingCode     String
  guestName       String
  guestEmail      String?
  roomNumber      String?
  subtotal        Decimal       @db.Decimal(12, 2)
  taxAmount       Decimal       @default(0) @db.Decimal(12, 2)
  discountAmount  Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal       @db.Decimal(12, 2)
  paidAmount      Decimal       @default(0) @db.Decimal(12, 2)
  balanceAmount   Decimal       @db.Decimal(12, 2)
  status          InvoiceStatus @default(UNPAID)
  currency        String        @default("AED")
  issuedAt        DateTime      @default(now())
  dueAt           DateTime?
  notes           String?
  createdByUserId String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  hotel           Hotel         @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  booking         Booking?      @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  guest           Guest?        @relation(fields: [guestId], references: [id], onDelete: SetNull)
  items           InvoiceItem[]
  payments        Payment[]
  receipts        Receipt[]

  @@unique([hotelId, invoiceNumber])
  @@index([hotelId, status, issuedAt])
  @@index([hotelId, bookingId])
}

model InvoiceItem {
  id         String   @id @default(cuid())
  invoiceId  String
  label      String
  quantity   Decimal  @default(1) @db.Decimal(10, 2)
  unitAmount Decimal  @db.Decimal(12, 2)
  amount     Decimal  @db.Decimal(12, 2)
  category   String   @default("OTHER")
  taxRate    Decimal  @default(0) @db.Decimal(5, 2)
  createdAt  DateTime @default(now())
  invoice    Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model PaymentGateway {
  id               String        @id @default(cuid())
  hotelId          String
  name             String
  method           PaymentMethod
  enabled          Boolean       @default(false)
  status           GatewayStatus @default(OFFLINE)
  settlementWindow String
  provider         String?
  configuration    Json?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  hotel            Hotel         @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([hotelId, method])
}

model Payment {
  id              String            @id @default(cuid())
  hotelId         String
  invoiceId       String
  receiptNumber   String
  guestName       String
  amount          Decimal           @db.Decimal(12, 2)
  method          PaymentMethod
  status          TransactionStatus @default(CAPTURED)
  reference       String
  processedAt     DateTime          @default(now())
  processedBy     String
  refundedAt      DateTime?
  refundReference String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  hotel           Hotel             @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  invoice         Invoice           @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  receipt         Receipt?

  @@unique([hotelId, receiptNumber])
  @@index([hotelId, status, processedAt])
  @@index([invoiceId])
}

model Receipt {
  id            String        @id @default(cuid())
  hotelId       String
  paymentId     String        @unique
  invoiceId     String
  receiptNumber String
  invoiceNumber String
  guestName     String
  amount        Decimal       @db.Decimal(12, 2)
  method        PaymentMethod
  issuedAt      DateTime      @default(now())
  createdAt     DateTime      @default(now())
  hotel         Hotel         @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  payment       Payment       @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  invoice       Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Restrict)

  @@unique([hotelId, receiptNumber])
  @@index([hotelId, issuedAt])
}

model Policy {
  id        String   @id @default(cuid())
  hotelId   String
  title     String
  category  String
  content   String
  version   Int      @default(1)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  hotel     Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([hotelId, title, version])
  @@index([hotelId, category, active])
}

model RoomCard {
  id             String           @id @default(cuid())
  hotelId        String
  roomId         String
  bookingId      String?
  guestName      String?
  status         CardStatus       @default(READY)
  accessType     AccessType
  credentialHash String?
  issuedAt       DateTime?
  expiresAt      DateTime?
  revokedAt      DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  hotel          Hotel            @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  room           Room             @relation(fields: [roomId], references: [id], onDelete: Cascade)
  booking        Booking?         @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  events         NfcAccessEvent[]

  @@index([hotelId, status])
  @@index([hotelId, roomId])
}

model NfcAccessEvent {
  id         String          @id @default(cuid())
  hotelId    String
  cardId     String
  event      AccessEventType
  location   String
  occurredAt DateTime        @default(now())
  metadata   Json?
  hotel      Hotel           @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  card       RoomCard        @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([hotelId, occurredAt])
  @@index([cardId, occurredAt])
}

model Blueprint {
  id        String          @id @default(cuid())
  hotelId   String
  name      String
  floor     Int
  width     Int             @default(1200)
  height    Int             @default(800)
  version   Int             @default(1)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  hotel     Hotel           @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  zones     BlueprintZone[]

  @@unique([hotelId, floor])
}

model BlueprintZone {
  id          String            @id @default(cuid())
  blueprintId String
  roomId      String?
  label       String
  type        BlueprintZoneType
  x           Int               @default(0)
  y           Int               @default(0)
  width       Int               @default(160)
  height      Int               @default(100)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  blueprint   Blueprint         @relation(fields: [blueprintId], references: [id], onDelete: Cascade)
  room        Room?             @relation(fields: [roomId], references: [id], onDelete: SetNull)

  @@index([blueprintId, type])
}

model Document {
  id         String       @id @default(cuid())
  hotelId    String
  title      String
  type       DocumentType
  linkedRef  String
  fileName   String?
  mimeType   String?
  storageKey String?
  checksum   String?
  sizeBytes  Int?
  metadata   Json?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  hotel      Hotel        @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId, type, createdAt])
  @@index([hotelId, linkedRef])
}

model Notification {
  id        String    @id @default(cuid())
  hotelId   String
  userId    String?
  title     String
  message   String
  severity  Priority
  audience  String
  readAt    DateTime?
  createdAt DateTime  @default(now())
  hotel     Hotel     @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([hotelId, audience, readAt, createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  hotelId    String
  userId     String?
  action     String
  actorName  String
  entityType String
  entityId   String
  target     String
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
  hotel      Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([hotelId, createdAt])
  @@index([hotelId, entityType, entityId])
}

model InventoryItem {
  id              String            @id @default(cuid())
  hotelId         String
  vendorId        String?
  name            String
  sku             String?
  category        InventoryCategory
  stockOnHand     Int
  reorderLevel    Int
  unit            String            @default("unit")
  unitCost        Decimal?          @db.Decimal(12, 2)
  storageLocation String?
  active          Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  hotel           Hotel             @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  vendor          Vendor?           @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  @@unique([hotelId, sku])
  @@index([hotelId, category, active])
}

model ShiftHandover {
  id         String     @id @default(cuid())
  hotelId    String
  department Department
  note       String
  author     String
  createdAt  DateTime   @default(now())
  hotel      Hotel      @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId, department, createdAt])
}

model NightAudit {
  id           String           @id @default(cuid())
  hotelId      String
  businessDate DateTime         @db.Date
  status       NightAuditStatus @default(PENDING)
  summary      String
  roomRevenue  Decimal          @default(0) @db.Decimal(12, 2)
  paymentTotal Decimal          @default(0) @db.Decimal(12, 2)
  openBalance  Decimal          @default(0) @db.Decimal(12, 2)
  completedBy  String?
  completedAt  DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  hotel        Hotel            @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([hotelId, businessDate])
  @@index([hotelId, status])
}

model Integration {
  id            String            @id @default(cuid())
  hotelId       String
  name          String
  type          IntegrationType
  enabled       Boolean           @default(false)
  status        IntegrationStatus @default(DISCONNECTED)
  configuration Json?
  lastSyncAt    DateTime?
  lastError     String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  hotel         Hotel             @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([hotelId, name])
  @@index([hotelId, type, enabled])
}

model RagDocument {
  id          String            @id @default(cuid())
  hotelId     String
  title       String
  storageKey  String
  fileType    String
  status      RagDocumentStatus @default(UPLOADED)
  checksum    String?
  processedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  hotel       Hotel             @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  chunks      RagChunk[]

  @@index([hotelId, status])
}

model RagChunk {
  id            String      @id @default(cuid())
  ragDocumentId String
  chunkIndex    Int
  content       String
  embedding     Json?
  metadata      Json?
  createdAt     DateTime    @default(now())
  document      RagDocument @relation(fields: [ragDocumentId], references: [id], onDelete: Cascade)

  @@unique([ragDocumentId, chunkIndex])
}

model AiInteraction {
  id               String   @id @default(cuid())
  hotelId          String
  userId           String?
  featureType      String
  prompt           String
  response         String
  sourceReferences Json?
  modelName        String?
  tokensUsed       Int?
  latencyMs        Int?
  createdAt        DateTime @default(now())
  hotel            Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId, featureType, createdAt])
}
